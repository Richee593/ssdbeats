<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<%- include("../partials/navbar") %>

<div class="admin-container">

  <h1>Edit News</h1>

  <form
    action="/admin/news/edit/<%= news._id %>"
    method="POST"
    enctype="multipart/form-data"
  >

    <!-- TITLE -->
    <div class="form-group">
      <label>Title</label>
      <input type="text" name="title" value="<%= news.title %>" required>
    </div>

    <!-- CATEGORY -->
    <div class="form-group">
      <label>Category</label>
      <input type="text" name="category" value="<%= news.category %>">
    </div>

    <!-- AUTHOR -->
    <div class="form-group">
      <label>Author</label>
      <input type="text" name="author" value="<%= news.author %>" readonly>
    </div>

    <!-- TAGS -->
    <div class="form-group">
      <label>Tags (comma separated)</label>
      <input
        type="text"
        name="tags"
        placeholder="music, artist, album"
        value="<%= news.tags.join(', ') %>"
      >
    </div>

    <!-- COVER IMAGE -->
    <div class="form-group">
      <label>Cover Image</label>

      <% if(news.coverImage){ %>
        <img id="coverPreview" src="<%= news.coverImage %>" width="150" style="margin-bottom:10px;border-radius:8px;">
      <% } else { %>
        <img id="coverPreview" style="display:none;width:150px;margin-bottom:10px;border-radius:8px;">
      <% } %>

      <input type="file" name="coverImage" id="coverInput">
    </div>

    <!-- CONTENT -->
    <div class="form-group">
      <label>Content</label>
      <div id="editor"><%- news.content %></div>
      <input type="hidden" name="content" id="content">
    </div>

    <button type="submit" class="btn-primary">
      Update News
    </button>

  </form>

</div>

<!-- QUILL JS -->
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<script>
  // ===== QUILL EDITOR =====
  const quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: 'Edit the news content here...',
    modules: {
      toolbar: [
        [{ header: [1, 2, 3, false] }],
        ['bold', 'italic', 'underline'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['link', 'image'],
        ['clean']
      ]
    }
  });

  const form = document.querySelector('form');

  form.onsubmit = function () {
    // Sync content
    document.querySelector('#content').value = quill.root.innerHTML;

    // Validation
    if (!form.title.value.trim()) {
      alert("Title cannot be empty");
      return false;
    }

    if (!quill.getText().trim()) {
      alert("Content cannot be empty");
      return false;
    }
  };

  // ===== COVER IMAGE PREVIEW =====
  const coverInput = document.getElementById("coverInput");
  const coverPreview = document.getElementById("coverPreview");

  coverInput.addEventListener("change", () => {
    const file = coverInput.files[0];
    if (file) {
      coverPreview.src = URL.createObjectURL(file);
      coverPreview.style.display = "block";
    }
  });
</script>

<style>
  .admin-container {
    max-width: 700px;
    margin: auto;
    padding: 20px;
  }

  .form-group {
    margin-bottom: 18px;
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    font-weight: 600;
    margin-bottom: 6px;
  }

  .form-group input,
  .form-group select,
  #editor {
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 5px;
  }

  #editor {
    min-height: 200px;
  }

  .btn-primary {
    background: #DFFF00;
    border: none;
    padding: 10px 20px;
    cursor: pointer;
    font-weight: bold;
    border-radius: 6px;
  }
</style>