<% if (success && success.length > 0) { %>
  <div class="alert alert-success"><%= success[0] %></div>
<% } %>

<% if (error && error.length > 0) { %>
  <div class="alert alert-error"><%= error[0] %></div>
<% } %>

<%- include("../partials/navbar") %>
<h2>Edit Artist</h2>

<form method="POST" enctype="multipart/form-data" class="artist-form">

<!-- NAME (SMART SEARCH) -->
<div class="form-group">
  <label>Artist Name</label>
  <input 
    type="text" 
    id="artistName"
    name="name" 
    value="<%= artist.name %>" 
    required 
    autocomplete="off"
  >
  <div id="artistSuggestions" class="search-results"></div>
</div>

<!-- BIO -->
<div class="form-group">
  <label>Bio</label>
  <textarea name="bio"><%= artist.bio %></textarea>
</div>

<!-- GENDER -->
<div class="form-group">
  <label>Gender</label>
  <select name="gender">
    <option value="">Select Gender</option>

    <option value="Male"
      <%= artist.gender === "Male" ? "selected" : "" %>>
      Male
    </option>

    <option value="Female"
      <%= artist.gender === "Female" ? "selected" : "" %>>
      Female
    </option>

    <option value="Group"
      <%= artist.gender === "Group" ? "selected" : "" %>>
      Group
    </option>
  </select>
</div>

<!-- IMAGE -->
<div class="form-group">
  <label>Artist Image</label>

  <% if (artist.image) { %>
    <img src="<%= artist.image %>" id="imagePreview" class="preview-img">
  <% } else { %>
    <img id="imagePreview" class="preview-img" style="display:none;">
  <% } %>

  <input type="file" name="image" id="imageInput">
</div>

<!-- SOCIAL LINKS -->
<h3>Social Media Links</h3>

<div class="form-group">
  <input type="text" name="instagram" placeholder="Instagram"
    value="<%= artist.socialLinks?.instagram || '' %>">

  <input type="text" name="facebook" placeholder="Facebook"
    value="<%= artist.socialLinks?.facebook || '' %>">

  <input type="text" name="twitter" placeholder="Twitter"
    value="<%= artist.socialLinks?.twitter || '' %>">

  <input type="text" name="youtube" placeholder="YouTube"
    value="<%= artist.socialLinks?.youtube || '' %>">

  <input type="text" name="tiktok" placeholder="TikTok"
    value="<%= artist.socialLinks?.tiktok || '' %>">

  <input type="text" name="audiomack" placeholder="Audiomack"
    value="<%= artist.socialLinks?.audiomack || '' %>">

  <input type="text" name="spotify" placeholder="Spotify"
    value="<%= artist.socialLinks?.spotify || '' %>">

  <input type="text" name="appleMusic" placeholder="Apple Music"
    value="<%= artist.socialLinks?.appleMusic || '' %>">
</div>

<br>

<button type="submit" class="btn-save">Update Artist</button>

</form>




<script>
const artists = <%- JSON.stringify(artists || []) %>;
const currentId = "<%= artist._id %>";

const input = document.getElementById("artistName");
const box = document.getElementById("artistSuggestions");

// 🔍 LIVE SEARCH (EXCLUDE CURRENT ARTIST)
input.addEventListener("input", () => {
  const query = input.value.toLowerCase();
  box.innerHTML = "";

  if (!query) return;

  const matches = artists
    .filter(a => a._id !== currentId)
    .filter(a => a.name.toLowerCase().includes(query));

  matches.forEach(a => {
    const div = document.createElement("div");
    div.classList.add("result-item");
    div.textContent = a.name;

    div.onclick = () => {
      input.value = a.name;
      box.innerHTML = "";
    };

    box.appendChild(div);
  });
});

// 🖼 IMAGE PREVIEW
const imageInput = document.getElementById("imageInput");
const preview = document.getElementById("imagePreview");

imageInput.addEventListener("change", () => {
  const file = imageInput.files[0];

  if (file) {
    preview.src = URL.createObjectURL(file);
    preview.style.display = "block";
  }
});
</script>




<style>

.artist-form{
  max-width:600px;
}

.form-group{
  margin-bottom:15px;
  display:flex;
  flex-direction:column;
}

.form-group label{
  font-weight:bold;
  margin-bottom:5px;
}

.form-group input,
.form-group textarea,
.form-group select{
  padding:10px;
  border:1px solid #ccc;
  border-radius:6px;
}

.search-results{
  border:1px solid #ccc;
  max-height:150px;
  overflow-y:auto;
  background:#fff;
}

.result-item{
  padding:8px;
  cursor:pointer;
}

.result-item:hover{
  background:#DFFF00;
}

.preview-img{
  width:80px;
  height:80px;
  object-fit:cover;
  border-radius:50%;
  margin-bottom:10px;
}

.btn-save{
  background:#DFFF00;
  border:none;
  padding:10px 18px;
  font-weight:bold;
  border-radius:6px;
  cursor:pointer;
}

</style>