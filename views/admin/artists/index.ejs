<% if (success && success.length > 0) { %>
  <div class="alert alert-success"><%= success[0] %></div>
<% } %>

<% if (error && error.length > 0) { %>
  <div class="alert alert-error"><%= error[0] %></div>
<% } %>
<%- include("../partials/navbar") %>
<h2>Artists</h2>

<div class="top-bar">
  <a href="/admin/artists/create" class="btn-add">+ Add Artist</a>

  <input type="text" id="artistSearch" placeholder="Search artists...">

  <select id="filterSelect">
    <option value="all">Sort: Default</option>
    <option value="a-z">A → Z</option>
    <option value="z-a">Z → A</option>
  </select>
</div>



<br>

<table class="artist-table">

  <thead>
    <tr>
      <th>Image</th>
      <th>Name</th>
      <th>Gender</th>
      <th>Bio</th>
      <th>Social</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody id="artistTableBody">

  <% artists.forEach(artist => { %>

    <tr class="artist-row">

      <!-- IMAGE -->
      <td>
        <% if (artist.image) { %>
          <img src="<%= artist.image %>" class="artist-img">
        <% } else { %>
          <div class="no-img">No</div>
        <% } %>
      </td>

      <!-- NAME -->
      <td class="artist-name">
        <strong><%= artist.name %></strong>
      </td>

      <!-- GENDER -->
      <td>
        <%= artist.gender || "N/A" %>
      </td>

      <!-- BIO -->
      <td class="bio">
        <%= artist.bio ? artist.bio.slice(0, 60) + "..." : "—" %>
      </td>

      <!-- SOCIAL -->
      <td class="social-links">

        <% if (artist.socialLinks) { %>

          <% if (artist.socialLinks.instagram) { %>
            <a href="<%= artist.socialLinks.instagram %>" target="_blank">IG</a>
          <% } %>

          <% if (artist.socialLinks.facebook) { %>
            <a href="<%= artist.socialLinks.facebook %>" target="_blank">FB</a>
          <% } %>

          <% if (artist.socialLinks.twitter) { %>
            <a href="<%= artist.socialLinks.twitter %>" target="_blank">TW</a>
          <% } %>

          <% if (artist.socialLinks.youtube) { %>
            <a href="<%= artist.socialLinks.youtube %>" target="_blank">YT</a>
          <% } %>

          <% if (artist.socialLinks.tiktok) { %>
            <a href="<%= artist.socialLinks.tiktok %>" target="_blank">TT</a>
          <% } %>

        <% } %>

      </td>

      <!-- ACTIONS -->
      <td>
        <a href="/admin/artists/edit/<%= artist._id %>" class="edit">Edit</a>
        |
        <form action="/admin/artists/delete/<%= artist._id %>" method="POST" style="display:inline;">
          <button type="submit" onclick="return confirm('Delete this artist?')">
            Delete
          </button>
        </form>
      </td>

    </tr>

  <% }) %>

  </tbody>

</table>



<script>
const searchInput = document.getElementById("artistSearch");
const filterSelect = document.getElementById("filterSelect");

searchInput.addEventListener("input", () => {
  const query = searchInput.value.toLowerCase();

  document.querySelectorAll(".artist-row").forEach(row => {
    const name = row.querySelector(".artist-name").textContent.toLowerCase();
    row.style.display = name.includes(query) ? "" : "none";
  });
});

filterSelect.addEventListener("change", () => {
  const tbody = document.getElementById("artistTableBody");
  const rows = Array.from(document.querySelectorAll(".artist-row"));

  if (filterSelect.value === "a-z") {
    rows.sort((a, b) =>
      a.querySelector(".artist-name").innerText
        .localeCompare(b.querySelector(".artist-name").innerText)
    );
  }

  if (filterSelect.value === "z-a") {
    rows.sort((a, b) =>
      b.querySelector(".artist-name").innerText
        .localeCompare(a.querySelector(".artist-name").innerText)
    );
  }

  rows.forEach(row => tbody.appendChild(row));
});



</script>
<script>
  setTimeout(() => {
    document.querySelectorAll('.alert').forEach(el => {
      el.style.opacity = "0";
      setTimeout(() => el.remove(), 500);
    });
  }, 3000);

  
</script>





<style>
  
  .top-bar{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    align-items:center;
  }
  
  #artistSearch{
    flex:1;
    padding:10px;
    border-radius:6px;
    border:1px solid #ccc;
  }
  
  #filterSelect{
    padding:10px;
    border-radius:6px;
  }
  
  .btn-add{
    background:#DFFF00;
    padding:10px 15px;
    text-decoration:none;
    font-weight:bold;
    border-radius:6px;
    color:black;
  }
  
  .artist-table{
    width:100%;
    border-collapse:collapse;
  }
  
  .artist-table th,
  .artist-table td{
    padding:10px;
    border-bottom:1px solid #ddd;
    text-align:left;
  }
  
  .artist-row:hover{
    background:#f9f9f9;
  }
  
  .artist-img{
    width:50px;
    height:50px;
    object-fit:cover;
    border-radius:50%;
  }
  
  .no-img{
    width:50px;
    height:50px;
    background:#ddd;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:12px;
  }
  
  .bio{
    max-width:200px;
  }
  
  .social-links a{
    margin-right:5px;
    font-size:12px;
    text-decoration:none;
  }
  
  .edit{
    color:blue;
  }
  
  .delete{
    color:red;
  }
  
  
  .alert {
    padding: 12px;
    margin-bottom: 15px;
    border-radius: 6px;
    font-weight: 500;
  }
  
  .alert.error {
    background: #ff4d4d;
    color: white;
  }
  
  .alert.success {
    background: #4CAF50;
    color: white;
  }
  
  .alert {
    transition: opacity 0.5s ease;
  }
</style>