<div class="login-container">

  <form method="POST" action="/admin/login" class="login-card">

    <h2>Admin Login</h2>

    <% if (error && error.length > 0) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <% if (success && success.length > 0) { %>
      <div class="alert success"><%= success %></div>
    <% } %>

    <input type="email" name="email" placeholder="Email" required>

    <input type="password" name="password" placeholder="Password" required>

    <button type="submit">Login</button>

  </form>

</div>

<style>

body{
  background:#0f0f0f;
  color:white;
  font-family:sans-serif;
}

.login-container{
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
}

.login-card{
  background:#1a1a1a;
  padding:40px;
  border-radius:12px;
  width:320px;
  display:flex;
  flex-direction:column;
  gap:15px;
  box-shadow:0 10px 30px rgba(0,0,0,0.5);
}

.login-card h2{
  text-align:center;
}

.login-card input{
  padding:10px;
  border:none;
  border-radius:6px;
  background:#222;
  color:white;
}

.login-card input:focus{
  outline:none;
  border:1px solid #DFFF00;
}

.login-card button{
  background:#DFFF00;
  border:none;
  padding:10px;
  font-weight:bold;
  cursor:pointer;
  border-radius:6px;
}

.login-card button:hover{
  opacity:0.9;
}

.alert{
  padding:8px;
  border-radius:5px;
  font-size:14px;
}

.alert.error{
  background:#ff4d4d;
}

.alert.success{
  background:#28a745;
}

</style>

<script>
setTimeout(() => {
  document.querySelectorAll('.alert').forEach(el => {
    el.style.display = 'none';
  });
}, 3000);
</script>