<div class="admin-container">

    <div class="admin-header">
        <h2>Edit Page</h2>
        <p><%= page.title %></p>
    </div>

    <div class="admin-card">

        <form action="/admin/pages/update/<%= page._id %>" method="POST">

            <!-- TITLE -->
            <div class="form-group">
                <label>Title</label>
                <input 
                    type="text" 
                    name="title" 
                    value="<%= page.title %>" 
                    required
                >
            </div>

            <!-- SLUG (READ ONLY) -->
            <div class="form-group">
                <label>Slug</label>
                <input 
                    type="text" 
                    value="<%= page.slug %>" 
                    disabled
                >
                <small>Slug cannot be changed</small>
            </div>

            <!-- STATUS -->
            <div class="form-group">
                <label>Status</label>
                <select name="status">
                    <option value="draft" <%= page.status === "draft" ? "selected" : "" %>>
                        Draft
                    </option>
                    <option value="published" <%= page.status === "published" ? "selected" : "" %>>
                        Published
                    </option>
                </select>
            </div>

            <!-- CONTENT -->
            <div class="form-group">
                <label>Content</label>

                <div id="editor" style="height:300px;">
                    <%- page.content %>
                </div>

                <input type="hidden" name="content" id="hiddenContent">
            </div>

            <!-- ACTIONS -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    Save Changes
                </button>

                <a href="/admin/pages" class="btn-cancel">
                    Cancel
                </a>
            </div>

        </form>

    </div>

</div>

<!-- QUILL CSS -->
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">

<!-- QUILL JS -->
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>

<script>
var quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: 'Write page content...',
    modules: {
        toolbar: [
            [{ header: [1, 2, 3, false] }],
            ['bold', 'italic', 'underline'],
            ['link', 'image'],
            [{ list: 'ordered'}, { list: 'bullet' }],
            [{ align: [] }],
            ['clean']
        ]
    }
});

document.querySelector("form").addEventListener("submit", function() {
    document.querySelector("#hiddenContent").value = quill.root.innerHTML;
});
</script>

<style>
.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 6px;
    font-weight: 600;
}

.form-group input,
.form-group select {
    width: 100%;
    padding: 10px;
    background: #111;
    border: 1px solid #333;
    color: #fff;
    border-radius: 6px;
}

.form-actions {
    margin-top: 20px;
}

.btn-save {
    background: #DFFF00;
    color: #000;
    padding: 10px 18px;
    border-radius: 6px;
    border: none;
    font-weight: bold;
    cursor: pointer;
}

.btn-cancel {
    margin-left: 10px;
    color: #aaa;
    text-decoration: none;
}

/* Quill Dark Style */
.ql-toolbar {
    background: #111;
    border: 1px solid #333;
}

.ql-container {
    background: #0b0b0b;
    color: #fff;
    border: 1px solid #333;
}
</style>