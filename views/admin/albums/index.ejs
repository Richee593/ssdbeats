<% if (success && success.length > 0) { %>
  <div class="alert alert-success"><%= success[0] %></div>
<% } %>

<% if (error && error.length > 0) { %>
  <div class="alert alert-error"><%= error[0] %></div>
<% } %>

<%- include("../partials/navbar") %>

<h2>Albums</h2>

<div class="top-bar">
  <a href="/admin/albums/create" class="btn-add">+ Add Album</a>

  <input type="text" id="albumSearch" placeholder="Search albums...">

  <select id="filterSelect">
    <option value="all">Sort: Default</option>
    <option value="a-z">Title A → Z</option>
    <option value="z-a">Title Z → A</option>
  </select>
</div>

<br>

<table class="album-table">

  <thead>
    <tr>
      <th>Cover</th>
      <th>Title</th>
      <th>Artist</th>
      <th>Genre</th>
      <th>Release Date</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody id="albumTableBody">

  <% albums.forEach(album => { %>

    <tr class="album-row">

      <!-- COVER -->
      <td>
        <% if (album.cover) { %>
          <img src="<%= album.cover %>" class="album-img">
        <% } else { %>
          <div class="no-img">No</div>
        <% } %>
      </td>

      <!-- TITLE -->
      <td class="album-title">
        <strong><%= album.title %></strong>
      </td>

      <!-- ARTIST -->
      <td class="album-artist">
        <%= album.artist ? album.artist.name : "N/A" %>
      </td>

      <!-- GENRE -->
      <td class="album-genre">
        <%= album.genre ? album.genre.name : "N/A" %>
      </td>

      <!-- DATE -->
      <td>
        <%= album.releaseDate 
          ? new Date(album.releaseDate).toLocaleDateString() 
          : "—" %>
      </td>

      <!-- ACTIONS -->
      <td>
        <a href="/admin/albums/edit/<%= album._id %>" class="edit">Edit</a>
        |
        <form action="/admin/albums/delete/<%= album._id %>" method="POST" style="display:inline;">
          <button type="submit" class="delete" onclick="return confirm('Delete this album?')">
            Delete
          </button>
        </form>
      </td>

    </tr>

  <% }) %>

  </tbody>

</table>

<% if (albums.length === 0) { %>
  <p>No albums yet. Start by adding one 🎧</p>
<% } %>

<script>
const searchInput = document.getElementById("albumSearch");
const filterSelect = document.getElementById("filterSelect");

// 🔍 SEARCH (title + artist + genre)
searchInput.addEventListener("input", () => {
  const query = searchInput.value.toLowerCase();

  document.querySelectorAll(".album-row").forEach(row => {
    const title = row.querySelector(".album-title").textContent.toLowerCase();
    const artist = row.querySelector(".album-artist")?.textContent.toLowerCase() || "";
    const genre = row.querySelector(".album-genre")?.textContent.toLowerCase() || "";
    
    const match = title.includes(query) || artist.includes(query) || genre.includes(query);

    row.style.display = match ? "" : "none";
  });
});

// 🔃 SORT
filterSelect.addEventListener("change", () => {
  const tbody = document.getElementById("albumTableBody");
  const rows = Array.from(document.querySelectorAll(".album-row"));

  if (filterSelect.value === "a-z") {
    rows.sort((a, b) =>
      a.querySelector(".album-title").innerText
        .localeCompare(b.querySelector(".album-title").innerText)
    );
  }

  if (filterSelect.value === "z-a") {
    rows.sort((a, b) =>
      b.querySelector(".album-title").innerText
        .localeCompare(a.querySelector(".album-title").innerText)
    );
  }

  rows.forEach(row => tbody.appendChild(row));
});
</script>
<script>
setTimeout(() => {
  document.querySelectorAll('.alert').forEach(el => {
    el.style.opacity = "0";
    setTimeout(() => el.remove(), 500);
  });
}, 3000);
</script>


<style>

.top-bar{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  align-items:center;
}

#albumSearch{
  flex:1;
  padding:10px;
  border-radius:6px;
  border:1px solid #ccc;
}

#filterSelect{
  padding:10px;
  border-radius:6px;
}

.btn-add{
  background:#DFFF00;
  padding:10px 15px;
  text-decoration:none;
  font-weight:bold;
  border-radius:6px;
  color:black;
}

.album-table{
  width:100%;
  border-collapse:collapse;
}

.album-table th,
.album-table td{
  padding:10px;
  border-bottom:1px solid #ddd;
  text-align:left;
}

.album-row:hover{
  background:#f9f9f9;
}

.album-img{
  width:50px;
  height:50px;
  object-fit:cover;
  border-radius:8px;
}

.no-img{
  width:50px;
  height:50px;
  background:#ddd;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:12px;
  border-radius:8px;
}

.edit{
  color:blue;
}

.delete{
  color:red;
}

</style>