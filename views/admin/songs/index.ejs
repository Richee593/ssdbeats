<%- include("../partials/navbar") %>

<h2>All Songs</h2>

<!-- Quick Add Button -->
<a href="/admin/songs/create" class="btn btn-primary">➕ Add New Song</a>

<!-- Search & Filter -->
<div class="songs-search-filter">
  <input type="text" id="songSearch" placeholder="Search by title or artist..." />

  <select id="filterFeatured">
    <option value="">All</option>
    <option value="featured">Featured</option>
  </select>
</div>

<!-- Songs Table -->
<table class="songs-table" border="1" cellpadding="10">
  <thead>
    <tr>
      <th>Title</th>
      <th>Artist</th>
      <th>Album</th>
      <th>Genre</th>
      <th>Plays</th>
      <th>Downloads</th>
      <th>Shares</th>
      <th>Likes</th>
      <th>Release Date</th>
      <th>Badges</th>
      <th>Audio</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody id="songsTableBody">
    <% if (songs.length === 0) { %>
      <tr>
        <td colspan="12">No songs available.</td>
      </tr>
    <% } %>

    <% songs.forEach(song => { %>
      <tr style="<%= song.isFeatured ? 'background:rgba(223,255,0,0.1);' : '' %>">

        <!-- TITLE -->
        <td><%= song.title %></td>

        <!-- ARTIST -->
        <td>
          <% if (song.mainArtist) { %>

            <strong><%= song.mainArtist.name %></strong>

            <% if (song.featuredArtists && song.featuredArtists.length > 0) { %>
              <span style="color:#888;">
                ft. <%= song.featuredArtists.map(a => a.name).join(", ") %>
              </span>
            <% } %>

          <% } else if (song.artist) { %>

            <%= song.artist.name %>

          <% } %>
        </td>

        <!-- ALBUM -->
        <td><%= song.album ? song.album.title : "N/A" %></td>

        <!-- GENRE -->
        <td><%= song.genre ? song.genre.name : "N/A" %></td>

        <!-- STATS -->
        <td><%= song.playCount || 0 %></td>
        <td><%= song.downloadCount || 0 %></td>
        <td><%= song.shareCount || 0 %></td>
        <td><%= song.likeCount || 0 %></td>

        <!-- RELEASE DATE -->
        <td>
          <%= song.releaseDate ? song.releaseDate.toDateString() : "N/A" %>
        </td>

        <!-- BADGES -->
        <td>
          <% if (song.isFeatured) { %>
            <span style="background:#DFFF00;color:#000;padding:3px 8px;border-radius:5px;font-size:12px;">
              FEATURED
            </span>
          <% } else { %>
            -
          <% } %>
        </td>

        <!-- AUDIO -->
        <td>
          <% if(song.audioFile){ %>
            <audio controls style="width:150px;">
              <source src="<%= song.audioFile %>" type="audio/mpeg" />
            </audio>
          <% } else { %>
            No Audio
          <% } %>
        </td>

        <!-- ACTIONS -->
        <td class="actions">

          <!-- EDIT -->
          <a href="/admin/songs/edit/<%= song._id %>">Edit</a> |

          <!-- DELETE (SAFE) -->
          <form action="/admin/songs/delete/<%= song._id %>" method="POST" style="display:inline;">
            <button type="submit" class="delete-song-btn">Delete</button>
          </form> |

          <!-- TOGGLE FEATURE -->
          <button class="toggle-feature-btn" data-id="<%= song._id %>">
            <%= song.isFeatured ? 'Unfeature' : 'Feature' %>
          </button>

        </td>

      </tr>
    <% }) %>
  </tbody>
</table>

<!-- JS -->
<script>

// 🔍 SEARCH (optimized)
const searchInput = document.getElementById('songSearch');
const tableBody = document.getElementById('songsTableBody');

searchInput.addEventListener('input', () => {
  const query = searchInput.value.toLowerCase();
  const rows = tableBody.querySelectorAll('tr');

  rows.forEach(row => {
    const title = row.children[0].textContent.toLowerCase();
    const artist = row.children[1].textContent.toLowerCase();

    row.style.display = (title + artist).includes(query) ? '' : 'none';
  });
});

// ⭐ FEATURE TOGGLE
document.querySelectorAll('.toggle-feature-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const songId = btn.dataset.id;

    try {
      const res = await fetch(`/admin/songs/toggle-feature/${songId}`, {
        method: 'POST'
      });

      const data = await res.json();

      btn.textContent = data.isFeatured ? 'Unfeature' : 'Feature';

      // Optional: reload to reflect badge + highlight
      location.reload();

    } catch(err) {
      console.error('Toggle feature error', err);
    }
  });
});

// 🗑 DELETE CONFIRM (SAFE)
document.querySelectorAll(".delete-song-btn").forEach(btn => {
  btn.addEventListener("click", function(e){

    const firstConfirm = confirm("Are you sure you want to delete this song?");
    if(!firstConfirm){
      e.preventDefault();
      return;
    }

    const secondConfirm = confirm("This action is permanent. Delete this song?");
    if(!secondConfirm){
      e.preventDefault();
    }

  });
});

</script>