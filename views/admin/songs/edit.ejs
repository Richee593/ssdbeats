<%- include("../partials/navbar") %>
<h2>Edit Song</h2>

<form action="/admin/songs/edit/<%= song._id %>" method="POST" enctype="multipart/form-data" class="song-form">

<!-- TITLE -->
<div class="form-group">
<label>Title</label>
<input type="text" name="title" value="<%= song.title %>" required>
</div>


<!-- ARTIST -->
<!-- MAIN ARTIST -->
<div class="form-group">
<label>Main Artist</label>

<input type="text" id="artistSearch" autocomplete="off"
value="<%= song.mainArtist?.name || song.artist?.name || '' %>">

<div id="artistResults" class="search-results"></div>

<input type="hidden" name="artist" id="artistValue"
value="<%= song.mainArtist?._id || song.artist?._id || '' %>" required>
</div>



<!-- FEATURED ARTISTS -->
<div class="form-group">
<label>Featured Artists (Optional)</label>

<input type="text" id="featuredSearch" placeholder="Search featured artists..." autocomplete="off">
<div id="featuredResults" class="search-results"></div>

<div id="featuredTags" class="tags-container"></div>

<input type="hidden" name="featuredArtists" id="featuredValues">
</div>


<!-- ALBUM -->
<div class="form-group">
<label>Album (Optional)</label>

<input type="text" id="albumSearch" autocomplete="off"
value="<%= song.album?.title || '' %>">

<div id="albumResults" class="search-results"></div>

<input type="hidden" name="album" id="albumValue"
value="<%= song.album?._id || '' %>">
</div>


<!-- GENRE -->
<div class="form-group">
<label>Genre</label>

<input type="text" id="genreSearch" autocomplete="off"
value="<%= song.genre?.name || '' %>">

<div id="genreResults" class="search-results"></div>

<input type="hidden" name="genre" id="genreValue"
value="<%= song.genre?._id || '' %>" required>
</div>


<!-- RELEASE DATE -->
<div class="form-group">

<label>Release Date</label>

<input
type="date"
name="releaseDate"
value="<%= song.releaseDate ? song.releaseDate.toISOString().split('T')[0] : '' %>"
>

</div>


<!-- CURRENT AUDIO -->

<div class="form-group">

<label>Current Audio</label>

<% if(song.audioFile){ %>

<audio controls>

<source src="<%= song.audioFile %>" type="audio/mpeg">

</audio>

<% } else { %>

<p>No audio uploaded</p>

<% } %>

</div>


<!-- REPLACE AUDIO -->

<div class="form-group">

<label>Replace Audio (Optional)</label>

<input type="file" name="audioFile" accept="audio/*" id="audioInput">

<audio id="audioPreview" controls style="display:none;margin-top:10px;"></audio>

</div>


<!-- CURRENT COVER -->

<div class="form-group">

<label>Current Cover</label>

<% if(song.coverImage){ %>

<img src="<%= song.coverImage %>" width="120" style="border-radius:8px">

<% } else { %>

<p>No cover uploaded</p>

<% } %>

</div>


<!-- REPLACE COVER -->

<div class="form-group">

<label>Replace Cover</label>

<input type="file" name="coverImage" accept="image/*" id="coverInput">

<img id="coverPreview" style="display:none;width:120px;margin-top:10px;border-radius:8px;">

</div>


<!-- FEATURED -->

<div class="form-group">

<label>
<input type="checkbox" name="isFeatured" value="true" <%= song.isFeatured ? "checked" : "" %>>
Feature this song

</label>

</div>


<!-- SONG STATS -->

<div class="stats-box">

<h3>Song Stats</h3>

<p>▶ Plays: <strong><%= song.playCount || 0 %></strong></p>

<p>⬇ Downloads: <strong><%= song.downloadCount || 0 %></strong></p>

<p>❤ Likes: <strong><%= song.likeCount || 0 %></strong></p>

<p>🔗 Shares: <strong><%= song.shareCount || 0 %></strong></p>

</div>

<div id="uploadBox" style="display:none; margin-top:15px;">
  <p>Uploading... <span id="progressText">0%</span></p>

  <div style="width:100%; background:#ddd; border-radius:8px; overflow:hidden;">
    <div id="progressBar" style="
      width:0%;
      height:10px;
      background:#DFFF00;
      transition: width 0.2s;
    "></div>
  </div>
</div>

<br>

<button type="submit" class="btn-save">Update Song</button>

<a href="/admin/songs" class="btn-cancel">Cancel</a>

</form>



<script>
const artists = <%- JSON.stringify(artists) %>;
const albums = <%- JSON.stringify(albums) %>;
const genres = <%- JSON.stringify(genres) %>;
const song = <%- JSON.stringify(song) %>;


// ===== SINGLE SEARCH =====
function setupSingleSearch(inputId, resultsId, hiddenId, data, key){
  const input = document.getElementById(inputId);
  const resultsBox = document.getElementById(resultsId);
  const hidden = document.getElementById(hiddenId);

  input.addEventListener("input", () => {
    const query = input.value.toLowerCase();
    resultsBox.innerHTML = "";

    if(!query) return;

    data
      .filter(item => item[key].toLowerCase().includes(query))
      .forEach(item => {
        const div = document.createElement("div");
        div.classList.add("result-item");
        div.textContent = item[key];

        div.onclick = () => {
          input.value = item[key];
          hidden.value = item._id;
          resultsBox.innerHTML = "";
        };

        resultsBox.appendChild(div);
      });
  });
}


// ===== FEATURED ARTISTS (WITH PRELOAD) =====
const featuredInput = document.getElementById("featuredSearch");
const featuredResults = document.getElementById("featuredResults");
const featuredTags = document.getElementById("featuredTags");
const featuredHidden = document.getElementById("featuredValues");

let selectedArtists = [];

// preload existing
if(song.featuredArtists){
  selectedArtists = song.featuredArtists.map(id => {
    return artists.find(a => a._id === id.toString());
  }).filter(Boolean);
  renderTags();
}

featuredInput.addEventListener("input", () => {
  const query = featuredInput.value.toLowerCase();
  featuredResults.innerHTML = "";

  if(!query) return;

  artists
    .filter(a => a.name.toLowerCase().includes(query))
    .forEach(artist => {

      if(selectedArtists.find(a => a._id === artist._id)) return;

      const div = document.createElement("div");
      div.classList.add("result-item");
      div.textContent = artist.name;

      div.onclick = () => {
        selectedArtists.push(artist);
        renderTags();
        featuredInput.value = "";
        featuredResults.innerHTML = "";
      };

      featuredResults.appendChild(div);
    });
});


function renderTags(){
  featuredTags.innerHTML = "";

  selectedArtists.forEach((artist, index) => {
    const tag = document.createElement("div");
    tag.classList.add("tag");
    tag.innerHTML = `
      ${artist.name}
      <span onclick="removeArtist(${index})">✕</span>
    `;
    featuredTags.appendChild(tag);
  });

  featuredHidden.value = selectedArtists.map(a => a._id).join(",");
}

function removeArtist(index){
  selectedArtists.splice(index,1);
  renderTags();
}


// ===== INIT SEARCHES =====
setupSingleSearch("artistSearch","artistResults","artistValue",artists,"name");
setupSingleSearch("albumSearch","albumResults","albumValue",albums,"title");
setupSingleSearch("genreSearch","genreResults","genreValue",genres,"name");


// ===== CLOSE DROPDOWNS =====
document.addEventListener("click", (e) => {
  if (!e.target.closest(".form-group")) {
    document.querySelectorAll(".search-results").forEach(box => box.innerHTML = "");
  }
});


// ===== AUDIO PREVIEW =====
audioInput.addEventListener("change", () => {
  const file = audioInput.files[0];
  if(file){
    audioPreview.src = URL.createObjectURL(file);
    audioPreview.style.display = "block";
  }
});

// ===== COVER PREVIEW =====
coverInput.addEventListener("change", () => {
  const file = coverInput.files[0];
  if(file){
    coverPreview.src = URL.createObjectURL(file);
    coverPreview.style.display = "block";
  }
});
</script>

<script>
const form = document.querySelector(".song-form");
const progressBox = document.getElementById("uploadBox");
const progressBar = document.getElementById("progressBar");
const progressText = document.getElementById("progressText");

form.addEventListener("submit", function(e) {
  e.preventDefault();

  const formData = new FormData(form);

  const xhr = new XMLHttpRequest();

  xhr.open("POST", form.action, true);

  // 🔥 SHOW LOADER
  progressBox.style.display = "block";

  // 🔥 TRACK PROGRESS
  xhr.upload.onprogress = function(e) {
    if (e.lengthComputable) {
      const percent = Math.round((e.loaded / e.total) * 100);

      progressBar.style.width = percent + "%";
      progressText.innerText = percent + "%";
    }
  };

  // ✅ SUCCESS
  xhr.onload = function() {
    if (xhr.status === 200 || xhr.status === 302) {
      progressText.innerText = "Done ✅";
      progressBar.style.width = "100%";

      // redirect after small delay
      setTimeout(() => {
        window.location.href = "/admin/songs";
      }, 800);
    } else {
      alert("Upload failed ❌");
    }
  };

  // ❌ ERROR
  xhr.onerror = function() {
    alert("Something went wrong ❌");
  };

  xhr.send(formData);
});
</script>

<style>

.song-form{
max-width:650px;
}

.form-group{
margin-bottom:18px;
display:flex;
flex-direction:column;
}

.form-group label{
font-weight:600;
margin-bottom:6px;
}

.form-group input,
.form-group select{
padding:8px;
border:1px solid #ccc;
border-radius:5px;
}

.warning{
color:red;
}

.stats-box{
background:#111;
color:white;
padding:15px;
border-radius:8px;
margin-top:20px;
}

.btn-save{
background:#DFFF00;
border:none;
padding:10px 18px;
cursor:pointer;
font-weight:bold;
border-radius:6px;
}

.btn-cancel{
margin-left:10px;
text-decoration:none;
}

</style>