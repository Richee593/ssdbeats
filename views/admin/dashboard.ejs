<h1>Admin Dashboard</h1>
<%- include("partials/navbar") %>

<!-- ========================= -->
<!-- STATS -->
<!-- ========================= -->

<div class="stats-grid">

  <a href="/admin/songs" class="card">
    Songs 
    <span><%= stats.totalSongs %></span>
  </a>

  <a href="/admin/artists" class="card">
    Artists 
    <span><%= stats.totalArtists %></span>
  </a>

  <a href="/admin/albums" class="card">
    Albums 
    <span><%= stats.totalAlbums %></span>
  </a>

  <a href="/admin/genres" class="card">
    Genres 
    <span><%= stats.totalGenres %></span>
  </a>

  <a href="/admin/news" class="card">
    News 
    <span><%= stats.totalNews %></span>
  </a>

  <!-- Analytics (non-clickable or future pages) -->
  <div class="card">
    Plays 
    <span><%= stats.totalPlays %></span>
  </div>

  <div class="card">
    Downloads 
    <span><%= stats.totalDownloads %></span>
  </div>

  <div class="card">
    Shares 
    <span><%= stats.totalShares %></span>
  </div>

</div>



<section class="quick-actions">

  <h2>Quick Actions</h2>

  <div class="actions-grid">

    <a href="/admin/songs/create" class="action-card">
      <span class="icon">🎵</span>
      <span>Add Song</span>
    </a>

    <a href="/admin/artists/create" class="action-card">
      <span class="icon">🎤</span>
      <span>Add Artist</span>
    </a>

    <a href="/admin/albums/create" class="action-card">
      <span class="icon">💿</span>
      <span>Add Album</span>
    </a>

    <a href="/admin/genres/create" class="action-card">
      <span class="icon">🎧</span>
      <span>Add Genre</span>
    </a>

    <a href="/admin/news/create" class="action-card">
      <span class="icon">📰</span>
      <span>Add News</span>
    </a>

    <a href="/admin/charts" class="action-card">
      <span class="icon">📈</span>
      <span>View Charts</span>
    </a>

  </div>

</section>




<section class="top-songs">

<h2>Top Performing Songs</h2>

<div class="top-grid">

<!-- MOST PLAYED -->

<div class="top-card">
<h3>🔥 Most Played</h3>
<ul>
<% mostPlayedSongs.forEach(song => { %>
<li>
<strong><%= song.title %></strong>
<span><%= song.artist?.name %></span>
</li>
<% }) %>
</ul>
</div>


<!-- MOST DOWNLOADED -->

<div class="top-card">
<h3>⬇️ Most Downloaded</h3>
<ul>
<% mostDownloadedSongs.forEach(song => { %>
<li>
<strong><%= song.title %></strong>
<span><%= song.artist?.name %></span>
</li>
<% }) %>
</ul>
</div>


<!-- MOST SHARED -->

<div class="top-card">
<h3>🔗 Most Shared</h3>
<ul>
<% mostSharedSongs.forEach(song => { %>
<li>
<strong><%= song.title %></strong>
<span><%= song.artist?.name %></span>
</li>
<% }) %>
</ul>
</div>


<!-- MOST LIKED -->

<div class="top-card">
<h3>❤️ Most Liked</h3>
<ul>
<% mostLikedSongs.forEach(song => { %>
<li>
<strong><%= song.title %></strong>
<span><%= song.artist?.name %></span>
</li>
<% }) %>
</ul>
</div>

</div>

</section>




<h2>📊 Platform Analytics</h2>

<div class="charts-grid">

  <div class="chart-card">
    <canvas id="playsChart"></canvas>
  </div>

  <div class="chart-card">
    <canvas id="downloadsChart"></canvas>
  </div>

  <div class="chart-card">
    <canvas id="sharesChart"></canvas>
  </div>

</div>



<!-- ========================= -->
<!-- TRENDING SONGS -->
<!-- ========================= -->

<h2>🔥 Trending Songs</h2>

<ul>
  <% trendingSongs.forEach(song => { %>
    <li>
      <strong><%= song.title %></strong>
      — <%= song.artist?.name %>
    </li>
  <% }) %>
</ul>


<!-- ========================= -->
<!-- RISING SONGS -->
<!-- ========================= -->

<h2>🚀 Rising Songs</h2>

<ul>
  <% risingSongs.forEach(song => { %>
    <li>
      <strong><%= song.title %></strong>
      — <%= song.artist?.name %>
    </li>
  <% }) %>
</ul>


<!-- ========================= -->
<!-- LATEST UPLOADS -->
<!-- ========================= -->

<h2>🎵 Latest Uploads</h2>

<ul>
  <% latestSongs.forEach(song => { %>
    <li>
      <strong><%= song.title %></strong>
      — <%= song.artist?.name %>
    </li>
  <% }) %>
</ul>


<!-- ========================= -->
<!-- GENRE DISTRIBUTION -->
<!-- ========================= -->

<h2>🎧 Songs by Genre</h2>

<ul>
  <% genreStats.forEach(g => { %>
    <li>
      <%= g._id %> — <%= g.total %> songs
    </li>
  <% }) %>
</ul>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const weeklyStats = <%- JSON.stringify(weeklyStats) %>;

const labels = weeklyStats.map(d => d._id);

const playsData = weeklyStats.map(d => d.plays);
const downloadsData = weeklyStats.map(d => d.downloads);
const sharesData = weeklyStats.map(d => d.shares);


/* Plays Chart */

new Chart(document.getElementById("playsChart"), {
  type: "line",
  data: {
    labels: labels,
    datasets: [{
      label: "Plays",
      data: playsData
    }]
  }
});


/* Downloads Chart */

new Chart(document.getElementById("downloadsChart"), {
  type: "line",
  data: {
    labels: labels,
    datasets: [{
      label: "Downloads",
      data: downloadsData
    }]
  }
});


/* Shares Chart */

new Chart(document.getElementById("sharesChart"), {
  type: "line",
  data: {
    labels: labels,
    datasets: [{
      label: "Shares",
      data: sharesData
    }]
  }
});

</script>



<style>

/* ===== GLOBAL ===== */
body {
  background: #0f0f0f;
  color: #fff;
  font-family: Arial, sans-serif;
}

h1, h2, h3 {
  margin-bottom: 10px;
}

/* ===== STATS GRID ===== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 15px;
  margin: 20px 0;
}

.card {
  background: #1a1a1a;
  padding: 20px;
  border-radius: 12px;
  text-align: center;
  transition: 0.2s;
  border: 1px solid #222;
}

.card span {
  display: block;
  font-size: 22px;
  margin-top: 10px;
  color: #DFFF00;
  font-weight: bold;
}

.card:hover {
  transform: translateY(-5px);
  border-color: #DFFF00;
}

/* ===== QUICK ACTIONS ===== */
.quick-actions {
  margin-top: 30px;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 15px;
}

.action-card {
  background: #1a1a1a;
  padding: 18px;
  border-radius: 12px;
  text-align: center;
  text-decoration: none;
  color: #fff;
  border: 1px solid #222;
  transition: 0.2s;
}

.action-card .icon {
  font-size: 24px;
  display: block;
  margin-bottom: 8px;
}

.action-card:hover {
  border-color: #DFFF00;
  color: #DFFF00;
  transform: translateY(-3px);
}

/* ===== TOP SONGS ===== */
.top-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 15px;
}

.top-card {
  background: #1a1a1a;
  padding: 15px;
  border-radius: 12px;
  border: 1px solid #222;
}

.top-card h3 {
  margin-bottom: 10px;
  color: #DFFF00;
}

.top-card ul {
  list-style: none;
  padding: 0;
}

.top-card li {
  margin-bottom: 8px;
  font-size: 14px;
}

.top-card li span {
  display: block;
  font-size: 12px;
  color: #aaa;
}

/* ===== CHARTS ===== */
.charts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
  margin: 20px 0;
}

.chart-card {
  background: #1a1a1a;
  padding: 15px;
  border-radius: 12px;
  border: 1px solid #222;
}

/* ===== LIST SECTIONS ===== */
ul {
  list-style: none;
  padding: 0;
}

ul li {
  padding: 10px;
  background: #1a1a1a;
  margin-bottom: 8px;
  border-radius: 8px;
  border: 1px solid #222;
  display: flex;
  justify-content: space-between;
}

ul li strong {
  color: #DFFF00;
}

/* ===== SECTION SPACING ===== */
section {
  margin-top: 30px;
}

/* ===== SCROLLBAR (OPTIONAL BUT NICE) ===== */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-thumb {
  background: #333;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #DFFF00;
}

</style>