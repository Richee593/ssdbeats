<%- include('../partials/header') %>
<%- include('../partials/navbar', { page: 'news' }) %>

<section class="news-page">

  <div class="container">

    <h1 class="page-title">Music News</h1>

    <div class="news-grid">

      <% news.forEach(item => { %>

        <% 
          const image = item.coverImage
            ? item.coverImage   // ✅ Cloudinary (already full URL)
            : "/images/hero.png";

          const plainText = item.content
            ? item.content.replace(/(<([^>]+)>)/gi, "")
            : "";

          const preview = plainText.substring(0, 120) + "...";
        %>

        <div class="news-card">

          <a href="/news/<%= item.slug %>">

            <!-- IMAGE -->
            <div class="news-image">

              <img
                src="<%= image %>"
                alt="<%= item.title %>"
                loading="lazy"
                decoding="async"
                onerror="this.src='/images/hero.png'"
              >

            </div>

            <!-- INFO -->
            <div class="news-info">

              <h3 class="news-title">
                <%= item.title %>
              </h3>

              <p class="news-preview">
                <%= preview %>
              </p>

              <p class="news-meta">
                <% if(item.category) { %>
                  <span class="news-category"><%= item.category %></span> •
                <% } %>

                <%= new Date(item.createdAt).toLocaleDateString() %>
              </p>

            </div>

          </a>

        </div>

      <% }) %>

    </div>

  </div>

</section>


<style>
  /* =========================
     NEWS PAGE
  ========================= */
  
  .news-page {
    padding: 20px 0 40px;
  }
  
  .news-page .container {
    width: 95%;
    max-width: 1300px;
    margin: auto;
  }
  
  /* TITLE */
  
  .page-title {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #fff;
  }
  
  /* GRID */
  
  .news-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  
  /* CARD */
  
  .news-card {
    background: #111;
    border-radius: 12px;
    overflow: hidden;
    transition: 0.2s ease;
    border: 1px solid #1f1f1f;
  }
  
  .news-card:hover {
    transform: translateY(-3px);
    border-color: #DFFF00;
  }
  
  .news-card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  
  /* IMAGE */
  
  .news-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #000;
  }
  
  .news-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: 0.3s ease;
  }
  
  .news-card:hover .news-image img {
    transform: scale(1.05);
  }
  
  /* INFO */
  
  .news-info {
    padding: 12px;
  }
  
  /* TITLE */
  
  .news-title {
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 6px;
    line-height: 1.3;
  }
  
  /* PREVIEW */
  
  .news-preview {
    font-size: 13px;
    color: #aaa;
    line-height: 1.4;
    margin-bottom: 8px;
  }
  
  /* META */
  
  .news-meta {
    font-size: 12px;
    color: #777;
  }
  
  .news-category {
    color: #DFFF00;
    font-weight: 500;
  }
  
  /* =========================
     RESPONSIVE
  ========================= */
  
  /* Large tablets */
  @media (max-width: 1100px) {
    .news-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  /* Tablets */
  @media (max-width: 800px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  
    .page-title {
      font-size: 24px;
    }
  }
  
  /* Phones */
  @media (max-width: 500px) {
    .news-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  
    .news-card {
      display: flex;
      flex-direction: row;
    }
  
    .news-image {
      width: 120px;
      min-width: 120px;
      aspect-ratio: 1 / 1;
    }
  
    .news-info {
      padding: 10px;
    }
  
    .news-title {
      font-size: 14px;
    }
  
    .news-preview {
      font-size: 12px;
    }
  }
  
  /* Very small screens (320px) */
  @media (max-width: 350px) {
  
    .news-image {
      width: 100px;
      min-width: 100px;
    }
  
    .news-title {
      font-size: 13px;
    }
  
    .news-preview {
      font-size: 11px;
    }
  
    .news-meta {
      font-size: 10px;
    }
  
    .page-title {
      font-size: 20px;
    }
  }
</style>