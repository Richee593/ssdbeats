<%- include('../partials/header') %>

<section class="single-news">

  <div class="container">

    <% 
      const cover = news.coverImage 
        ? news.coverImage 
        : "/images/hero.png";

      const cleanText = news.content
        ? news.content.replace(/(<([^>]+)>)/gi, "")
        : "";

      const readTime = Math.max(1, Math.ceil(cleanText.split(" ").length / 200));
    %>

    <!-- HEADER -->
    <div class="news-header">

      <h1 class="news-title"><%= news.title %></h1>

      <p class="news-meta">
        <span class="author"><%= news.author || "SSD Beats" %></span> •
        <span><%= new Date(news.createdAt).toDateString() %></span> •
        <span><%= readTime %> min read</span>
      </p>

    </div>

    <!-- COVER -->
    <div class="news-cover">

      <img
        src="<%= cover %>"
        alt="<%= news.title %>"
        loading="lazy"
        decoding="async"
        onerror="this.src='/images/hero.png'"
      >

    </div>

    <!-- CONTENT -->
    <div class="news-content">

      <%- news.content %>

    </div>

    <!-- TAGS -->
    <% if(news.tags && news.tags.length) { %>
      <div class="news-tags">
        <% news.tags.forEach(tag => { %>
          <a href="/news/tag/<%= tag %>" class="tag">
            #<%= tag %>
          </a>
        <% }) %>
      </div>
    <% } %>

  </div>

</section>


<!-- RELATED / LATEST NEWS -->
<section class="related-news">

  <div class="container">

    <h2>Latest News</h2>

    <div class="news-grid">

      <% latest.forEach(item => { %>

        <% 
          const image = item.coverImage 
            ? item.coverImage 
            : "/images/hero.png";
        %>

        <div class="news-card">

          <a href="/news/<%= item.slug %>">

            <div class="news-image">
              <img
                src="<%= image %>"
                alt="<%= item.title %>"
                loading="lazy"
                onerror="this.src='/images/hero.png'"
              >
            </div>

            <div class="news-info">
              <h4><%= item.title %></h4>
            </div>

          </a>

        </div>

      <% }) %>

    </div>

  </div>

</section>


<!-- SEO STRUCTURED DATA -->
<script type="application/ld+json">
{
 "@context": "https://schema.org",
 "@type": "NewsArticle",
 "headline": "<%= news.title %>",
 "image": "<%= cover %>",
 "datePublished": "<%= news.createdAt.toISOString() %>",
 "dateModified": "<%= news.updatedAt ? news.updatedAt.toISOString() : news.createdAt.toISOString() %>",
 "author": {
   "@type": "Organization",
   "name": "<%= news.author || 'SSD Beats' %>"
 },
 "publisher": {
   "@type": "Organization",
   "name": "SSD Beats"
 },
 "mainEntityOfPage": {
   "@type": "WebPage",
   "@id": "<%= canonicalUrl %>"
 }
}
</script>

<style>

/* =========================
   SINGLE NEWS PAGE
========================= */

.single-news {
  padding: 20px 0 40px;
}

.single-news .container {
  width: 95%;
  max-width: 900px;
  margin: auto;
}

/* HEADER */

.news-header {
  margin-bottom: 20px;
}

.single-news .news-title {
  font-size: 32px;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
  margin-bottom: 10px;
}

.news-meta {
  font-size: 13px;
  color: #888;
}

.news-meta .author {
  color: #DFFF00;
  font-weight: 500;
}

/* COVER */

.news-cover {
  margin: 20px 0;
  border-radius: 14px;
  overflow: hidden;
}

.news-cover img {
  width: 100%;
  height: auto;
  display: block;
}

/* CONTENT */

.news-content {
  color: #ddd;
  font-size: 16px;
  line-height: 1.7;
}

.news-content p {
  margin-bottom: 16px;
}

.news-content img {
  max-width: 100%;
  border-radius: 10px;
  margin: 15px 0;
}

.news-content h2,
.news-content h3 {
  color: #fff;
  margin: 20px 0 10px;
}

.news-content a {
  color: #DFFF00;
  text-decoration: none;
}

.news-content a:hover {
  text-decoration: underline;
}

/* TAGS */

.news-tags {
  margin-top: 25px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  background: #111;
  border: 1px solid #222;
  padding: 6px 10px;
  border-radius: 20px;
  font-size: 12px;
  text-decoration: none;
  color: #ccc;
  transition: 0.2s ease;
}

.tag:hover {
  border-color: #DFFF00;
  color: #DFFF00;
}

/* =========================
   RELATED NEWS
========================= */

.related-news {
  padding: 30px 0 50px;
}

.related-news h2 {
  color: #fff;
  margin-bottom: 15px;
}

.related-news .container {
  width: 95%;
  max-width: 1200px;
  margin: auto;
}

.news-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.related-news .news-card {
  background: #111;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid #1f1f1f;
  transition: 0.2s ease;
}

.related-news .news-card:hover {
  border-color: #DFFF00;
  transform: translateY(-3px);
}

.related-news .news-card a {
  text-decoration: none;
  color: inherit;
  display: block;
}

.related-news .news-image {
  aspect-ratio: 16/9;
  overflow: hidden;
}

.related-news .news-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.related-news .news-info {
  padding: 8px;
}

.related-news .news-info h4 {
  font-size: 13px;
  color: #fff;
  line-height: 1.3;
}

/* =========================
   RESPONSIVE
========================= */

/* Tablet */
@media (max-width: 900px) {

  .single-news .news-title {
    font-size: 26px;
  }

  .news-content {
    font-size: 15px;
  }

  .news-grid {
    grid-template-columns: repeat(2, 1fr);
  }

}

/* Phones */
@media (max-width: 600px) {

  .single-news .news-title {
    font-size: 22px;
  }

  .news-meta {
    font-size: 12px;
  }

  .news-content {
    font-size: 14px;
    line-height: 1.6;
  }

  .news-grid {
    grid-template-columns: 1fr;
  }

}

/* Small phones */
@media (max-width: 400px) {

  .single-news .news-title {
    font-size: 20px;
  }

  .news-content {
    font-size: 13px;
  }

  .tag {
    font-size: 11px;
    padding: 5px 8px;
  }

}

/* Very small screens */
@media (max-width: 320px) {

  .single-news .news-title {
    font-size: 18px;
  }

  .news-meta {
    font-size: 11px;
  }

  .news-content {
    font-size: 12px;
  }

}

</style>