<%
  const link = "/albums/" + album._id;

  const image = album.coverImage
    || album.cover
    || "/images/default-album.png";

  const title = album.title || "Untitled Album";

  const artistName = album.artist
    ? album.artist.name
    : "Unknown Artist";
%>

<a href="<%= link %>" class="album-card">

  <!-- STACKED COVER -->
  <div class="album-stack">
    <img src="<%= image %>" class="album-cover main" alt="<%= title %>" loading="lazy">
    <img src="<%= image %>" class="album-cover back" alt="">
  </div>

  <!-- INFO -->
  <div class="album-info">
    <p class="album-title"><%= title %></p>
    <p class="album-artist"><%= artistName %></p>
  </div>

</a>