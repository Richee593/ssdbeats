<!-- Album Header -->
<!-- Album Header -->
<div class="ap-header">
  <% const albumCover = album.cover || "/images/default-album.png"; %>
  <% const artistName = album.artist ? album.artist.name : "Unknown Artist"; %>

  <img src="<%= albumCover %>" alt="<%= album.title %>" class="ap-cover">

  <div class="ap-info">
    <h1 class="ap-title"><%= album.title %></h1>
    <p class="ap-artist">By <%= artistName %></p>

    <% if(album.releaseDate) { %>
      <p class="ap-release">Released: <%= new Date(album.releaseDate).toDateString() %></p>
    <% } %>

    <div class="ap-stats">
      <span class="ap-stat-songs">Songs: <%= stats.totalSongs %></span>
      <span class="ap-stat-plays">Plays: <%= stats.totalPlays %></span>
      <span class="ap-stat-downloads">Downloads: <%= stats.totalDownloads %></span>
    </div>
  </div>
</div>


<!-- Songs -->
<div class="album-song-list">
  <% albumSongs.forEach((song, index) => { 
        const songImage = song.coverImage || albumCover || "/images/default-song.png";
        const audio = song.audioFile || "";
        const songArtist = song.artist ? song.artist.name : artistName;
        const songLink = "/songs/" + song._id;
  %>
    <a href="<%= songLink %>" class="album-song-item-link">
      <div class="album-song-item">
        <img src="<%= songImage %>" alt="<%= song.title %>">
        <div class="album-song-info">
          <div class="album-song-title"><%= song.title %></div>
          <div class="album-song-artist"><%= songArtist %></div>
        </div>

        <% if(audio) { %>
          <button class="play-btn" 
            type="button"
            data-index="<%= index %>"
            data-id="<%= song._id %>" 
            data-audio="<%= audio %>" 
            data-title="<%= song.title %>" 
            data-artist="<%= songArtist %>" 
            data-cover="<%= songImage %>"
            onclick="event.preventDefault(); event.stopPropagation(); playSong(<%= index %>)">
            ▶
          </button>
        <% } else { %>
          <span class="no-audio">No Audio</span>
        <% } %>
      </div>
    </a>
  <% }) %>
</div>

<script>
let audio = new Audio();
let currentIndex = -1;
let isPlaying = false;
let playSubmitted = false; // Track if play has been counted

function playSong(index){
  const btn = document.querySelector(`.play-btn[data-index="${index}"]`);
  const row = btn.closest(".album-song-item");

  const song = {
    id: btn.dataset.id,
    audio: btn.dataset.audio,
    title: btn.dataset.title,
    artist: btn.dataset.artist,
    cover: btn.dataset.cover
  };

  // Reset playSubmitted if switching songs
  if(currentIndex !== index){
    playSubmitted = false;
  }

  if(currentIndex === index){
    if(isPlaying){
      audio.pause();
      isPlaying = false;
      btn.innerHTML = "▶";
      row.classList.remove("active");
    } else {
      audio.play();
      isPlaying = true;
      btn.innerHTML = "❚❚";
      row.classList.add("active");
    }
    return;
  }

  audio.pause();
  currentIndex = index;
  audio.src = song.audio;
  audio.play();
  isPlaying = true;

  document.querySelectorAll(".album-song-item").forEach(r => r.classList.remove("active"));
  document.querySelectorAll(".play-btn").forEach(b => b.innerHTML = "▶");

  row.classList.add("active");
  btn.innerHTML = "❚❚";

  updateGlobalPlayer(song);
}

// AUTO NEXT
audio.addEventListener("ended",()=>{
  let next = currentIndex + 1;
  if(next >= document.querySelectorAll(".play-btn").length) next = 0;
  playSong(next);
});

// Count a play only after 20 seconds
audio.addEventListener("timeupdate", () => {
  if(!playSubmitted && audio.currentTime >= 20 && currentIndex !== -1){
    playSubmitted = true;
    const songId = document.querySelector(`.play-btn[data-index="${currentIndex}"]`).dataset.id;
    submitPlay(songId);
  }
});

// Global Player Functions
function updateGlobalPlayer(song){
  const title = document.querySelector("#global-title");
  const artist = document.querySelector("#global-artist");
  const cover = document.querySelector("#global-cover");

  if(title) title.textContent = song.title;
  if(artist) artist.textContent = song.artist;
  if(cover) cover.src = song.cover;
}

// Submit play to API and update album stats
function submitPlay(songId){
  fetch(`/api/player/play/${songId}`, { method: "POST" })
    .then(res => res.json())
    .then(data => {
      if(data.success){
        // Update album header stats live
        const playsEl = document.querySelector(".album-stats span.plays");
        if(playsEl) playsEl.textContent = `Plays: ${data.playCount}`;
      }
    })
    .catch(err => console.log("Play count error", err));
}
</script>


<style>

