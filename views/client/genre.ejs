<%- include('partials/header') %>


<section class="songs-page">

  <!-- HEADER -->
  <div class="page-header">
    <h1><%= genre.name %></h1>
    <p>Explore <%= genre.name %> music</p>
  </div>

  <!-- NAV -->
  <div class="songs-nav">
    <a href="#all" class="active">🎯 All</a>
    <a href="#trending">🔥 Trending</a>
    <a href="#rising">🚀 Rising</a>
    <a href="#new">🆕 New</a>
  </div>

  <!-- ================= -->
  <!-- ALL SONGS -->
  <!-- ================= -->
  <section id="all" class="song-section">
    <h2>🎯 All Songs</h2>

    <div class="songs-grid">
      <% songs.forEach(song => { %>
        <%- include('partials/song-card', { song }) %>
      <% }) %>
    </div>

    <!-- PAGINATION -->
    <div class="pagination">
      <% if(currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %>">Prev</a>
      <% } %>

      <% for(let i=1; i<=totalPages; i++) { %>
        <a href="?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>">
          <%= i %>
        </a>
      <% } %>

      <% if(currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %>">Next</a>
      <% } %>
    </div>
  </section>

  <!-- ================= -->
  <!-- TRENDING -->
  <!-- ================= -->
  <section id="trending" class="song-section">
    <h2>🔥 Trending in <%= genre.name %></h2>

    <div class="songs-grid">
      <% trendingSongs.forEach(song => { %>
        <%- include('partials/song-card', { song }) %>
      <% }) %>
    </div>
  </section>

  <!-- ================= -->
  <!-- RISING -->
  <!-- ================= -->
  <section id="rising" class="song-section">
    <h2>🚀 Rising in <%= genre.name %></h2>

    <div class="songs-grid">
      <% risingSongs.forEach(song => { %>
        <%- include('partials/song-card', { song }) %>
      <% }) %>
    </div>
  </section>

  <!-- ================= -->
  <!-- NEW -->
  <!-- ================= -->
  <section id="new" class="song-section">
    <h2>🆕 New in <%= genre.name %></h2>

    <div class="songs-grid">
      <% newSongs.forEach(song => { %>
        <%- include('partials/song-card', { song }) %>
      <% }) %>
    </div>
  </section>

</section>

<script>
  // Active nav highlight + smooth scroll
  document.querySelectorAll('.songs-nav a').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();

      document.querySelectorAll('.songs-nav a')
        .forEach(a => a.classList.remove('active'));

      link.classList.add('active');

      document.querySelector(link.getAttribute('href'))
        .scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>

<style>
/* ========================= SONGS PAGE ========================= */
.songs-page {
  padding: 20px;
  color: #fff;
}

/* ========================= PAGE HEADER ========================= */
.page-header {
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid #222;
  text-align: center;
}

.page-header h1 {
  font-size: 28px;
  color: #DFFF00; /* brand color */
  margin-bottom: 5px;
}

.page-header p {
  font-size: 14px;
  color: #ccc;
  margin: 0;
}

/* ========================= SONGS NAV ========================= */
.songs-nav {
  display: flex;
  overflow-x: auto;
  white-space: nowrap;
  gap: 10px;
  background-color: #111;
  padding: 10px 15px;
  border-radius: 8px;
  margin-bottom: 20px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin;
  scrollbar-color: #DFFF00 #222;
}

/* Scrollbar styling for Webkit browsers */
.songs-nav::-webkit-scrollbar {
  height: 6px;
}

.songs-nav::-webkit-scrollbar-track {
  background: #222;
  border-radius: 3px;
}

.songs-nav::-webkit-scrollbar-thumb {
  background: #DFFF00;
  border-radius: 3px;
}

/* Nav links */
.songs-nav a {
  display: inline-block;
  padding: 8px 18px;
  border-radius: 6px;
  text-decoration: none;
  color: #fff;
  font-weight: 500;
  font-size: 1rem;
  transition: all 0.3s ease;
  border: 1px solid transparent;
  flex-shrink: 0;
  white-space: nowrap;
}

.songs-nav a:hover, .songs-nav a.active {
  background-color: #DFFF00;
  color: #111;
  border-color: #DFFF00;
}

/* Responsive adjustments */
@media (max-width: 1200px) {
  .page-header h1 {
    font-size: 24px;
  }
  .songs-nav a {
    padding: 7px 14px;
    font-size: 0.95rem;
  }
}

@media (max-width: 992px) {
  .page-header h1 {
    font-size: 22px;
  }
  .songs-nav a {
    padding: 6px 12px;
    font-size: 00.9rem;
  }
}

@media (max-width: 768px) {
  .songs-page {
    padding: 15px;
  }
  .page-header h1 {
    font-size: 20px;
  }
  .page-header p {
    font-size: 12px;
  }
  .songs-nav a {
    padding: 5px 10px;
    font-size: 0.85rem;
  }
}

@media (max-width: 480px) {
  .songs-page {
    padding: 10px;
  }
  .page-header h1 {
    font-size: 18px;
  }
  .page-header p {
    font-size: 11px;
  }
  .songs-nav a {
    padding: 4px 8px;
    font-size: 0.8rem;
  }
}

@media (max-width: 340px) {
  .page-header h1 {
    font-size: 16px;
  }
  .songs-nav a {
    padding: 3px 6px;
    font-size: 0.75rem;
  }
}
  
</style>